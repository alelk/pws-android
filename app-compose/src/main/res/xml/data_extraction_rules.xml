<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="pws.db" />
        <exclude domain="database" path="pws.db-shm" />
        <exclude domain="database" path="pws.db-wal" />
        <exclude domain="sharedpref" path="pws_db_security_v2.xml" />
        <exclude domain="sharedpref" path="pws_db_security.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="pws.db" />
        <exclude domain="database" path="pws.db-shm" />
        <exclude domain="database" path="pws.db-wal" />
        <exclude domain="sharedpref" path="pws_db_security_v2.xml" />
        <exclude domain="sharedpref" path="pws_db_security.xml" />
    </device-transfer>
</data-extraction-rules>
