# Compose app smoke/E2E configuration (Phase 1 - local)
# APK_PATH is resolved automatically from app.version (output/compose/pws-app-release-{version}-ru.apk).
# Override here only if needed:
# APK_PATH="/abs/path/to/custom.apk"
APP_ID="com.alelk.pws.pwapp"

# Stable, locale-independent selectors (match contentDescription values set in pws-core/features).
# Navigation tabs
NAV_HOME="home"
NAV_SEARCH="search"
NAV_BOOKS="books"
NAV_TAGS="tags"
NAV_FAVORITES="favorites"
NAV_HISTORY="history"

# Actions
ACTION_TOGGLE_FAVORITE="action:toggle-favorite"
ACTION_MORE="action:more-actions"
ACTION_EDIT_SONG="action:edit-song"
ACTION_EDIT_TAGS="action:edit-tags"
ACTION_SAVE="action:save"
ACTION_ADD_TAG="action:add-tag"
ACTION_SAVE_TAG="action:save-tag"
ACTION_SAVE_SONG_TAGS="action:save-song-tags"

# Fields
FIELD_SEARCH="field:search"
FIELD_TAG_NAME="field:tag-name"
FIELD_SONG_EDIT_TITLE="field:song-edit-title"

# Numeric search query — guaranteed to produce results in any flavour; locale-independent.
SEARCH_QUERY_NUMERIC="1"
# Unique word from the song "Слушайте повесть любви в простоте" (song #1).
# Use this to reliably find a specific song regardless of search-result ordering.
SEARCH_QUERY_UNIQUE="Слушайте"
# Title fragment used as a Maestro tap target after searching.
SONG_TITLE_UNIQUE="Слушайте"

# Stable content description pattern present on every song list row.
# Use regex "song-row-.*" in flows to match any song-row-N element.
SONG_LIST_ITEM_PREFIX="song-row-"
SONG_ITEM_ONE="song-row-1"
RECENT_ITEM_PREFIX="Recently viewed"

# Test data — English only, no locale dependency.
TEST_TAG_NAME="E2E_SMOKE_TAG"
TEST_SONG_EDIT_TITLE="E2E Edited Title"

# Phase 2: settings, quick actions, number search, history clear
ACTION_OPEN_SETTINGS="action:open-settings"
ACTION_NUMBER_SEARCH="action:number-search"
ACTION_TEXT_SEARCH="action:text-search"
ACTION_CLEAR_HISTORY="action:clear-history"
ACTION_CONFIRM_CLEAR_HISTORY="action:confirm-clear-history"

# Home inline search suggestions
FIELD_HOME_SEARCH="field:home-search"
HOME_SUGGESTION_ZERO="home-suggestion-0"

# Number input modal
FIELD_NUMBER_INPUT="field:number-input"
NUMBER_SUGGESTION_ZERO="number-suggestion-0"

# Tag list items (pattern: "tag-row-{name}")
TAG_ROW_PREFIX="tag-row-"

# Home recently viewed section
HOME_SECTION_RECENTLY_VIEWED="home-section-recently-viewed"
RECENT_SONG_CARD_ZERO="recent-song-card-0"


